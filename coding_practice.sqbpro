ndex="9" value="127"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">CREATE TABLE quiz_questions (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    category TEXT,
    difficulty TEXT,
    question_text TEXT,
    option_a TEXT,
    option_b TEXT,
    option_c TEXT,
    option_d TEXT,
    correct_option TEXT
);
-- Core Runtime &amp; Mechanics
INSERT INTO quiz_questions (category, difficulty, question_text, option_a, option_b, option_c, option_d, correct_option) VALUES
('Runtime', 'Easy', 'Which component is directly responsible for executing Python bytecode instructions?', 'Python Source Compiler', 'Python Virtual Machine', 'C-PreProcessor', 'Operating System Kernel', 'B'),
('Runtime', 'Easy', 'What is the default filename extension used for cached bytecode files generated by the runtime?', '.py', '.pyc', '.pyd', '.obj', 'B'),
('Runtime', 'Medium', 'How does the CPython interpreter enforce atomic evaluation safety across OS threads?', 'Using memory barriers', 'Via the Global Interpreter Lock', 'Through software transactional memory', 'By spawning isolated processes', 'B'),
('Runtime', 'Medium', 'Which environment variable dictates the path lookup order for imported custom modules?', 'PYTHONHOME', 'PYTHONPATH', 'PYTHONSTARTUP', 'PYTHONBIN', 'B'),
('Runtime', 'Hard', 'What subsystem handles cyclic isolates that reference counting misses?', 'The generational garbage collector', 'The stack frame allocator', 'The global type dictionary', 'The AST optimizer', 'A'),
('Runtime', 'Easy', 'Which built-in mechanism exposes standard identifier lookups like ValueError or len?', 'Enclosing Scope', 'Global Namespace', 'Built-in Namespace', 'Local Dictionary', 'C'),
('Runtime', 'Medium', 'What does evaluating the expression &quot;id(x) == id(y)&quot; confirm if it evaluates to True?', 'They contain identical semantic data', 'They occupy the same memory location', 'They share the same data hash value', 'They share an identical type inheritance', 'B'),
('Runtime', 'Hard', 'What structural alteration occurs via the process called &quot;name mangling&quot;?', 'Prefixing a single underscore', 'Appending a trailing underscore', 'Prefixing two underscores without trailing ones', 'Wrapping the identifier in double underscores', 'C'),
('Runtime', 'Easy', 'What rule dictates how identifier symbols are resolved across nested blocks?', 'LIFO rule', 'FIFO rule', 'LEGB rule', 'RAII rule', 'C'),
('Runtime', 'Medium', 'Which native routine yields explicit user-facing inline metadata bound to a function structure?', 'inspect.getsource()', 'help()', 'dir()', 'type()', 'B');

-- Advanced Type Semantics
INSERT INTO quiz_questions (category, difficulty, question_text, option_a, option_b, option_c, option_d, correct_option) VALUES
('Data Types', 'Easy', 'Which native data structure completely prohibits the insertion of duplicate values?', 'List', 'Tuple', 'Set', 'Dictionary', 'C'),
('Data Types', 'Easy', 'What structural trait defines an immutable object type?', 'Its reference location changes frequently', 'Its internal state cannot be modified post-instantiation', 'It cannot accept string keys', 'It lacks a string conversion method', 'B'),
('Data Types', 'Medium', 'What type of structural replica duplicates top-level references while retaining shared inner collection references?', 'Deep copy', 'Shallow copy', 'Bitwise clone', 'Virtual assignment', 'B'),
('Data Types', 'Medium', 'Why are native lists disqualified from serving as keys within standard dictionaries?', 'They lack an iterative protocol', 'They are structurally mutable and unhashable', 'They occupy variable memory segments', 'They do not support sorting algorithms', 'B'),
('Data Types', 'Hard', 'Which constructor generates a structural collection initialized with no items?', 'dict()', 'set()', 'tuple()', 'All of the above', 'D'),
('Data Types', 'Easy', 'What syntactic token sequence allows a developer to perform index-based slicing?', '[start:stop:step]', '(start, stop, step)', '{start; stop; step}', '&lt;start..stop..step&gt;', 'A'),
('Data Types', 'Medium', 'What is the evaluation outcome of the expression &quot;bool([])&quot;?', 'True', 'False', 'None', 'Raises a ValueError', 'B'),
('Data Types', 'Medium', 'Which operation modifies an existing list object directly in memory without producing a new list?', '.append()', '.extend()', '.pop()', 'All of the above', 'D'),
('Data Types', 'Hard', 'What happens if you execute standard string slicing with a step value of -1?', 'An IndexError is raised', 'The sequence order is inverted', 'The first and last indices switch spots', 'The string drops its white spaces', 'B'),
('Data Types', 'Easy', 'Which built-in category accommodates the storage of mapped keys paired with records?', 'Sequence type', 'Mapping type', 'Set type', 'Numeric type', 'B');

-- Syntactic Comprehensions
INSERT INTO quiz_questions (category, difficulty, question_text, option_a, option_b, option_c, option_d, correct_option) VALUES
('Syntax', 'Easy', 'What structural symbol defines a list comprehension processing pipeline?', 'Parentheses', 'Square brackets', 'Curly braces', 'Angle brackets', 'B'),
('Syntax', 'Medium', 'How do you structure an inline syntax loop to generate key-value dictionaries?', '{k: v for k, v in items}', '[k: v for k, v in items]', '(k: v for k, v in items)', '{k, v for k, v in items}', 'A'),
('Syntax', 'Hard', 'What object type is instantiated when writing a comprehension enclosed in soft parentheses ()?', 'Tuple', 'List Generator', 'Generator Expression', 'Frozen Set', 'C'),
('Syntax', 'Easy', 'Where is a filtering evaluation placement positioned inside standard comprehension syntax?', 'Before the loop initialization', 'Directly after the final iterable expression', 'Inside a nested lambda function', 'Within an explicit exception clause', 'B'),
('Syntax', 'Medium', 'Which scenario warrants nested comprehensions over traditional loop patterns?', 'When optimizing code execution speed dramatically', 'When processing multidimensional arrays in single clean lines', 'When executing non-pure side effects', 'When interacting with file system streams', 'B'),
('Syntax', 'Easy', 'What character acts as the element separation token within a set comprehension?', 'Semicolon', 'Comma', 'Pipe symbol', 'Colon', 'B'),
('Syntax', 'Medium', 'Can a comprehension structure integrate an inline &quot;if-else&quot; expression?', 'No, it only allows standard trailing &quot;if&quot; filters', 'Yes, by putting the conditional prior to the loop clause', 'Yes, but only within dictionary contexts', 'No, this causes an immediate SyntaxError', 'B'),
('Syntax', 'Hard', 'What resource management trap occurs when misusing infinite range inputs in list comprehensions?', 'Immediate Out-Of-Memory exhaustion', 'Silent data truncation', 'Type mutation to floating points', 'Automatic thread starvation', 'A'),
('Syntax', 'Easy', 'Which keyword provides logical filtration capabilities within a basic comprehension expression?', 'while', 'if', 'switch', 'assert', 'B'),
('Syntax', 'Medium', 'What data type is generated by the expression &quot;{val for val in [1, 2, 2]}&quot;?', 'List', 'Set', 'Dictionary', 'Tuple', 'B');

-- Functional Architecture
INSERT INTO quiz_questions (category, difficulty, question_text, option_a, option_b, option_c, option_d, correct_option) VALUES
('Functions', 'Easy', 'What notation unpacks a variable list of positional parameters into a function block?', '**kwargs', '*args', '&amp;args', '$$args', 'B'),
('Functions', 'Easy', 'What definition describes an anonymous single-expression functional block?', 'Dynamic Method', 'Lambda Function', 'Static Closure', 'Abstract Routine', 'B'),
('Functions', 'Medium', 'What data structure collects extra named keyword arguments passed into a function parameter marked with **?', 'List', 'Tuple', 'Dictionary', 'Set', 'C'),
('Functions', 'Medium', 'What programmatic pattern returns a inner function that remembers its enclosing scope variables?', 'Generator', 'Closure', 'Decorator', 'Coroutine', 'B'),
('Functions', 'Hard', 'How can you restrict a function parameter to be passed exclusively via positional syntax?', 'By adding a trailing asterisk (*)', 'By placing a forward slash (/) after the parameter', 'By wrapping the argument name in quotes', 'By declaring it inside a global block', 'B'),
('Functions', 'Easy', 'Which keyword terminates execution and yields a value back from a standard function body?', 'break', 'return', 'yield', 'pass', 'B'),
('Functions', 'Medium', 'What structural artifact modifies a target function pattern without hacking its internal source syntax?', 'Generator', 'Decorator', 'Interface', 'Context Manager', 'B'),
('Functions', 'Hard', 'What behavior occurs if a mutable collection type is assigned as a default parameter value?', 'It re-instantiates an empty instance upon every invocation', 'It shares the same mutable reference state across all calls', 'It causes an immediate SyntaxError during parsing', 'It locks the argument to prevent runtime edits', 'B'),
('Functions', 'Easy', 'What value is implicitly returned by a function containing no explicit return statement?', '0', 'False', 'None', 'An empty string', 'C'),
('Functions', 'Medium', 'Which function parameter signature structure is syntactically invalid?', 'def calc(a, b=2, *args)', 'def calc(a=1, b)', 'def calc(*args, **kwargs)', 'def calc(a, *args, b=2)', 'B');

-- Object-Oriented Blueprinting
INSERT INTO quiz_questions (category, difficulty, question_text, option_a, option_b, option_c, option_d, correct_option) VALUES
('OOP', 'Easy', 'What structure acts as the object instance factory blueprint?', 'Module', 'Class', 'Package', 'Namespace', 'B'),
('OOP', 'Easy', 'Which special dunder framework method serves as the instance initializer constructor?', '__new__', '__init__', '__start__', '__call__', 'B'),
('OOP', 'Medium', 'What explicit reference tracking variable must be assigned as the primary argument in instance methods?', 'this', 'cls', 'self', 'super', 'C'),
('OOP', 'Medium', 'Which mechanism enables a child class to tap into initialization sequences of its base ancestor parent?', 'super()', 'parent()', 'base()', 'this()', 'A'),
('OOP', 'Hard', 'What algorithmic methodology does Python implement to resolve method lookups in multiple inheritance hierarchies?', 'Depth-First Search', 'Breadth-First Search', 'C3 Linearization (MRO)', 'Liskov Substitution Protocol', 'C'),
('OOP', 'Easy', 'What OOP architectural principle models an &quot;is-a&quot; structural derivation relationship?', 'Encapsulation', 'Polymorphism', 'Inheritance', 'Abstraction', 'C'),
('OOP', 'Medium', 'How do you define a true static method attribute within a standard class definitions file?', 'By prefixing the method name with an underscore', 'By omitting the self parameter entirely', 'By utilizing the @staticmethod decorator', 'By declaring the method inside the __init__ pipeline', 'C'),
('OOP', 'Hard', 'What structural purpose does the special object slot syntax &quot;__slots__&quot; achieve?', 'It automatically serializes class definitions into binary', 'It optimizes instance memory footprint by suppressing __dict__ creation', 'It enforces strict strict parameter typing on instantiation', 'It allows multiple inheritance interfaces to cross-compile', 'B'),
('OOP', 'Easy', 'Which built-in tool assesses whether an object instance shares a structural lineage with a target class?', 'type()', 'isinstance()', 'issubclass()', 'dir()', 'B'),
('OOP', 'Medium', 'What behavior does the @classmethod decorator induce on its target method routine?', 'It binds the method first argument to the underlying class reference instead of an instance', 'It compiles the method to bypass the global interpreter lock', 'It prevents downstream sub-classes from overriding the code block', 'It converts returned dictionaries into standard JSON representations', 'A');

-- Iteration &amp; Control Execution
INSERT INTO quiz_questions (category, difficulty, question_text, option_a, option_b, option_c, option_d, correct_option) VALUES
('Control Flow', 'Easy', 'Which keyword forces an execution timeline out of its immediate loop segment completely?', 'continue', 'break', 'pass', 'return', 'B'),
('Control Flow', 'Easy', 'What design purpose does the &quot;pass&quot; directive satisfy?', 'It resets the loop condition tracker', 'It operates as a syntactic placeholder that does nothing', 'It throws a managed operational exception code', 'It transfers execution tracking to a parallel thread', 'B'),
('Control Flow', 'Medium', 'When does the conditional &quot;else&quot; block tied to a &quot;while&quot; or &quot;for&quot; loop run?', 'When the loop terminates due to an explicit break statement', 'Only if the loop fails to complete its initial structural iteration', 'When the loop iteration completes naturally without hitting a break statement', 'Whenever an unhandled exception triggers inside the block', 'C'),
('Control Flow', 'Medium', 'What protocol interface method fetches consecutive records from an iterator collection wrapper?', '__iter__()', '__next__()', '__step__()', '__advance__()', 'B'),
('Control Flow', 'Hard', 'What key operational constraint separates a generator routine from a conventional data array factory?', 'Generators compute values lazily and stream them on-demand via yield', 'Generators require thread synchronization hooks to run safely', 'Generators can only parse float metrics natively', 'Generators cache all output values inside memory registers', 'A'),
('Control Flow', 'Easy', 'Which keyword advances a running loop directly to its next sequential evaluation frame?', 'break', 'pass', 'continue', 'exit', 'C'),
('Control Flow', 'Medium', 'Which function creates an indexed series tracker from a sequential list input?', 'zip()', 'enumerate()', 'range()', 'map()', 'B'),
('Control Flow', 'Hard', 'What exception object is thrown by an iterator to announce it has exhausted its collection stream?', 'EOFError', 'StopIteration', 'IndexError', 'LookupError', 'B'),
('Control Flow', 'Easy', 'Which loop architecture is ideal when the precise iteration volume is unknown beforehand?', 'for loop', 'while loop', 'do-while loop', 'switch loop', 'B'),
('Control Flow', 'Medium', 'What built-in factory produces a synchronized parallel data stream pairing matching components from discrete sets?', 'combine()', 'zip()', 'merge()', 'map()', 'B');

-- Robust Exception Management
INSERT INTO quiz_questions (category, difficulty, question_text, option_a, option_b, option_c, option_d, correct_option) VALUES
('Exceptions', 'Easy', 'Which block handles errors raised inside a guarded code context?', 'try', 'except', 'finally', 'else', 'B'),
('Exceptions', 'Easy', 'What distinguishes a SyntaxError from operational exceptions like ZeroDivisionError?', 'SyntaxError occurs during compile parsing; Exceptions occur at runtime', 'SyntaxError can be mitigated via structural except blocks', 'Exceptions terminate operating system kernels directly', 'SyntaxError only triggers inside object subclass structures', 'A'),
('Exceptions', 'Medium', 'Which block is guaranteed to execute regardless of whether an exception was raised or handled?', 'except', 'else', 'finally', 'catch', 'C'),
('Exceptions', 'Medium', 'What keyword allows a developer to programmatically trigger a specific error type?', 'throw', 'raise', 'trigger', 'assert', 'B'),
('Exceptions', 'Hard', 'What scenario executes the optional conditional block marked &quot;else&quot; inside an exception architecture?', 'When an exception is raised and successfully suppressed', 'When the try block executes cleanly without encountering any errors', 'When the finally sequence encounters a system resource dead lock', 'When a custom error class bypasses standard tracking classes', 'B'),
('Exceptions', 'Easy', 'Which exception type handles dictionary lookup failures when targeting non-existent keys?', 'IndexError', 'KeyError', 'ValueError', 'TypeError', 'B'),
('Exceptions', 'Medium', 'How do you intercept multiple independent exception variations inside a single except block statement?', 'By stacking keywords sequentially without spaces', 'By wrapping error types within a standard comma-separated tuple', 'By mapping alternative exception strings inside a dictionary wrapper', 'By isolating separate logic streams within an inline lambda block', 'B'),
('Exceptions', 'Hard', 'What diagnostic structural track maps the nested execution history leading to an unhandled runtime crash?', 'Memory trace dumps', 'Traceback log records', 'Compilation sequence charts', 'AST block frameworks', 'B'),
('Exceptions', 'Easy', 'Which keyword validates boolean code constraints, throwing an error if the assertion evaluates to False?', 'try', 'raise', 'assert', 'verify', 'C'),
('Exceptions', 'Medium', 'What standard baseline parent class inherits architectural features to custom application errors?', 'SystemExit', 'BaseException', 'Exception', 'GeneratorExit', 'C');

-- Scientific Ecosystem (NumPy / Pandas)
INSERT INTO quiz_questions (category, difficulty, question_text, option_a, option_b, option_c, option_d, correct_option) VALUES
('Data Science', 'Easy', 'Which base tool provides vectorized array storage configurations for data workflows?', 'Pandas', 'NumPy', 'Matplotlib', 'SciPy', 'B'),
('Data Science', 'Easy', 'What core structural object class represents an interactive multidimensional layout in Pandas?', 'Series', 'DataFrame', 'Matrix', 'Panel', 'B'),
('Data Science', 'Medium', 'Which Pandas selection indexer targets metrics explicitly by their coordinate label strings?', 'iloc', 'loc', 'ix', 'at_index', 'B'),
('Data Science', 'Medium', 'How do you eliminate records with null metrics from a targeted DataFrame schema?', '.fillna()', '.dropna()', '.clear()', '.remove()', 'B'),
('Data Science', 'Hard', 'What core performance optimization enables NumPy array operations to outperform traditional Python list loops?', 'Continuous uniform memory allocation and compiled C-underpinnings', 'Dynamic variable re-typing pipelines', 'Automatic integration with distributed multi-threading workers', 'Native application of system database indexes', 'A'),
('Data Science', 'Easy', 'Which method reads comma-separated files into a standard DataFrame layout structure?', 'pd.load_file()', 'pd.read_csv()', 'pd.open_data()', 'pd.parse_table()', 'B'),
('Data Science', 'Medium', 'Which indexer allows integer-position based slicing within Pandas datasets?', 'loc', 'iloc', 'idx', 'pos', 'B'),
('Data Science', 'Medium', 'What underlying object structure represents a isolated individual column within a Pandas DataFrame grid?', 'Array', 'Series', 'Vector', 'List', 'B'),
('Data Science', 'Hard', 'How does a Pandas evaluation handle cell replacements via the method command statement &quot;.fillna(0)&quot;?', 'It modifies all non-numerical data parameters to boolean zeros', 'It replaces missing or null data occurrences with a value of zero', 'It truncates incomplete row structures from the data array', 'It maps an additional validation matrix layer over index pointers', 'B'),
('Data Science', 'Easy', 'Which method returns a summary of structural metrics like mean and standard deviation from a data table?', '.info()', '.describe()', '.head()', '.summary()', 'B');

-- Modular Engineering &amp; Testing
INSERT INTO quiz_questions (category, difficulty, question_text, option_a, option_b, option_c, option_d, correct_option) VALUES
('Engineering', 'Easy', 'What specialized folder initialization component marks directory maps as importable packages?', '__main__.py', '__init__.py', 'setup.py', 'config.py', 'B'),
('Engineering', 'Easy', 'Which native test module framework evaluates isolated unit structures from source projects?', 'pytest', 'unittest', 'nose', 'doctest', 'B'),
('Engineering', 'Medium', 'What shell configuration syntax grants an executable file attribute status across UNIX terminals?', 'chmod +x script.py', 'chown root script.py', 'run script.py', 'exec script.py', 'A'),
('Engineering', 'Medium', 'What prefix token pattern designates class attribute fields as implicitly protected from external manipulation?', 'Double trailing underscore', 'Single leading underscore', 'Double leading underscore', 'All-caps naming formats', 'B'),
('Engineering', 'Hard', 'What shell header sequence instructs terminal scripts to run code structures under a specific python runtime path?', '#!/usr/bin/env python3', 'import sys', 'sys.path.append()', 'python.exe --run', 'A'),
('Engineering', 'Easy', 'Which module isolates explicit fixed-type mathematical array blocks as an alternative to native lists?', 'collections', 'array', 'struct', 'math', 'B'),
('Engineering', 'Medium', 'How can you isolate external module installations across independent isolated sandboxes?', 'By tweaking system hardware partitions', 'By configuring virtual environments via venv', 'By modifying global environment variables', 'By adjusting text editor runtime configs', 'B'),
('Engineering', 'Hard', 'What strategy prevents code blocks inside an imported module script from triggering automatically during configuration loading?', 'Wrapping logic blocks within an &quot;if __name__ == ''__main__''&quot; condition', 'Encrypting internal function declarations prior to export', 'Renaming the source file structure to block automated compilation', 'Compiling the module directly into a static wheel distribution format', 'A'),
('Engineering', 'Easy', 'Which command tracking keyword checks structural state variables inside test suite scripts?', 'verify', 'assert', 'check', 'expect', 'B'),
('Engineering', 'Medium', 'Which built-in module tracks, records, and routes system warning updates or event logs during app execution?', 'syslog', 'logging', 'traceback', 'warnings', 'B');

-- String Processing &amp; Analytics
INSERT INTO quiz_questions (category, difficulty, question_text, option_a, option_b, option_c, option_d, correct_option) VALUES
('Strings', 'Easy', 'Which string class adjustment method replaces empty spaces with an explicit alternative target character?', '.swap()', '.replace()', '.convert()', '.translate()', 'B'),
('Strings', 'Easy', 'What term identifies a word structural sequence that reads identically from left-to-right as right-to-left?', 'Anagram', 'Palindrome', 'Isogram', 'Homonym', 'B'),
('Strings', 'Medium', 'What slicing syntax completely reverses a string sequence without calling loop structures?', '[::1]', '[::-1]', '[-1::]', '[1::-1]', 'B'),
('Strings', 'Medium', 'Which structural format joins distinct elements from a list into a combined string sequence using a designated spacer?', '.split()', '.join()', '.concat()', '.merge()', 'B'),
('Strings', 'Hard', 'What design constraint applies to string manipulation behaviors across core Python environments?', 'Strings are immutable; changes yield a completely new string object', 'Strings allocate memory dynamically across separate network systems', 'Strings require conversion to floating arrays to support slicing modifications', 'Strings are strictly isolated from multi-character lookup operations', 'A'),
('Strings', 'Easy', 'Which method normalizes a text value by converting all of its characters to lowercase?', '.lower()', '.casefold()', '.strip()', 'Both A and B', 'D'),
('Strings', 'Medium', 'Which string evaluation check returns a boolean True if a text sequence terminates with a specific substring target?', '.contains()', '.endswith()', '.has_suffix()', '.match()', 'B'),
('Strings', 'Hard', 'What method strips leading and trailing whitespaces from a string target without altering inner spacing?', '.clear()', '.strip()', '.clean()', '.truncate()', 'B'),
('Strings', 'Easy', 'Which method segments a string into an ordered array of substrings based on a delimiter character?', '.divide()', '.split()', '.partition()', '.break()', 'B'),
('Strings', 'Medium', 'What format prefix creates an interpolated string literal that embeds inline variables directly into text?', 'r&quot;&quot;', 'f&quot;&quot;', 'b&quot;&quot;', 'u&quot;&quot;', 'B');</sql><current_tab id="0"/></tab_sql></sqlb_project>
